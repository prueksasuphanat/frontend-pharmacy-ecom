# Backend API base URL
# Development: http://localhost:3000/api/v1
# Production: https://api.phanadrug.com หรือ https://phanadrug.com/api
VITE_API_BASE_URL=http://localhost:3000/api/v1

# AWS S3 (for prescription uploads)
# VITE_S3_BUCKET_URL=https://your-bucket.s3.ap-southeast-1.amazonaws.com

# App config
VITE_APP_NAME=Phanadrug
VITE_APP_VERSION=1.0.0
